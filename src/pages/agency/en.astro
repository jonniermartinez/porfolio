            <div class="text-slate-400 text-sm">Projects Delivered</div>
          </div>
          <div class="text-center bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="text-3xl md:text-4xl font-black text-white mb-1">5+</div>
            <div class="text-slate-400 text-sm">Years of Experience</div>
          </div>
          <div class="text-center bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="text-3xl md:text-4xl font-black text-white mb-1">2</div>
            <div class="text-slate-400 text-sm">Own Products</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="py-20 md:py-28 relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-500/30 to-transparent"></div>
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-5xl md:text-6xl font-black text-white mb-4">SERVICES</h2>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">
            Complete tech solutions to take your business to the next level
          </p>

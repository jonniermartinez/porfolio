          <div class="relative bg-gradient-to-b from-violet-500/10 to-transparent border border-violet-500/20 rounded-3xl p-8 md:p-10 flex flex-col">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-violet-600 text-white text-sm font-bold px-5 py-1.5 rounded-full">
              MÁS POPULAR
            </div>

            <div class="text-center mb-8">
              <h3 class="text-2xl font-bold text-white mb-2">Plan Mensual</h3>
              <p class="text-slate-400 text-sm mb-6">Ideal para mantenimiento y mejoras continuas</p>

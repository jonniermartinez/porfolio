          <!-- Servicio 3: Automatizaciones -->
          <div class="group bg-white/5 border border-white/10 rounded-2xl p-8 hover:border-violet-500/30 hover:bg-violet-500/5 transition-all duration-300">
            <div class="w-14 h-14 bg-violet-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-violet-500/20 transition-colors">
              <svg class="w-7 h-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Automatizaciones</h3>
            <p class="text-slate-400 leading-relaxed mb-4">
              Automatiza procesos repetitivos y ahorra tiempo. Integraciones, bots, flujos de trabajo y conexiones entre herramientas que trabajan por ti.
            </p>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Integraciones API
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Bots & workflows
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Reportes automáticos
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- PLANES / PRICING -->
    <section id="planes" class="py-20 md:py-28 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-violet-950/10 via-transparent to-violet-950/10"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-500/30 to-transparent"></div>

      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <h2 class="text-5xl md:text-6xl font-black text-white mb-4">PLANES</h2>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">

---
import "@fontsource-variable/onest";
import "@/styles/tailwind.css";
import SEOTags from "@/components/seo/SEOTags.astro";
---

<!DOCTYPE html>
<html lang="es">
  <SEOTags title="Jonnier Martinez | Agency - Desarrollo Web & Software" />

  <body class="bg-[#0a0a0a] text-slate-300 font-normal text-base selection:bg-violet-500 selection:text-white">
    <!-- Background -->
    <div class="fixed inset-0 z-[-10] bg-[#0a0a0a]" />

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-[#0a0a0a]/90 backdrop-blur-md border-b border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-white hover:text-violet-400 transition-colors">
          Jonnier Martinez
        </a>
        <div class="flex items-center gap-3">
          <a
            href="/agency/en"
            class="text-sm text-slate-400 hover:text-white transition-colors border border-white/10 px-3 py-1.5 rounded-full hover:border-white/30"
          >
            EN
          </a>
          <a
            href="#planes"
            class="bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors"
          >
            Ver Planes
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="relative overflow-hidden">
      <!-- Gradient orbs -->
      <div class="absolute top-[-200px] left-[-100px] w-[500px] h-[500px] bg-violet-600/20 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-100px] right-[-100px] w-[400px] h-[400px] bg-indigo-600/15 rounded-full blur-[100px]"></div>

      <div class="max-w-5xl mx-auto px-6 py-24 md:py-36 text-center relative z-10">
        <div class="inline-block bg-violet-500/10 border border-violet-500/20 text-violet-300 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
          Desarrollo Web & Software a tu medida
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight mb-6">
          Convierte tu idea en un
          <span class="bg-gradient-to-r from-violet-400 to-indigo-400 bg-clip-text text-transparent">
            producto digital real
          </span>
        </h1>

        <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          Desarrollo de <strong class="text-white">páginas web</strong>, <strong class="text-white">software a medida</strong> y <strong class="text-white">automatizaciones</strong> que impulsan tu negocio. Soy desarrollador freelance con productos propios y proyectos reales en producción.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#planes"
            class="bg-violet-600 hover:bg-violet-500 text-white font-bold px-8 py-4 rounded-full text-lg transition-all hover:scale-105 hover:shadow-lg hover:shadow-violet-500/25"
          >
            Ver Planes y Precios
          </a>
          <a
            href="#servicios"
            class="border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-4 rounded-full text-lg transition-all hover:bg-white/5"
          >
            Conocer Servicios
          </a>
        </div>
      </div>
    </section>

    <!-- QUIÉNES SOMOS -->
    <section class="relative py-20 md:py-28">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet-950/10 to-transparent"></div>
      <div class="max-w-5xl mx-auto px-6 relative z-10">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
              QUIÉN<br/>SOY
            </h2>
            <p class="text-slate-400 leading-relaxed text-lg">
              Soy Jonnier Martinez, desarrollador freelance especializado en construir productos digitales reales que generan resultados.
              Con experiencia creando aplicaciones propias y proyectos para clientes, entiendo lo que se necesita para llevar una idea del concepto al producto funcional.
            </p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-2xl p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-3 h-3 rounded-full bg-violet-500"></div>
              <span class="text-violet-300 font-semibold text-sm uppercase tracking-wider">Mi filosofía</span>
            </div>
            <p class="text-white text-lg font-medium italic leading-relaxed">
              "No solo construyo software, creo soluciones que transforman la manera en que tu negocio opera y crece en el mundo digital."
            </p>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mt-16">
          <div class="text-center bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="text-3xl md:text-4xl font-black text-white mb-1">50+</div>
            <div class="text-slate-400 text-sm">Proyectos Entregados</div>
          </div>
          <div class="text-center bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="text-3xl md:text-4xl font-black text-white mb-1">5+</div>
            <div class="text-slate-400 text-sm">Años de Experiencia</div>
          </div>
          <div class="text-center bg-white/5 border border-white/10 rounded-xl p-6">
            <div class="text-3xl md:text-4xl font-black text-white mb-1">2</div>
            <div class="text-slate-400 text-sm">Productos Propios</div>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="py-20 md:py-28 relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-500/30 to-transparent"></div>
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-5xl md:text-6xl font-black text-white mb-4">SERVICIOS</h2>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">
            Soluciones tecnológicas completas para llevar tu negocio al siguiente nivel
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Servicio 1: Páginas Web -->
          <div class="group bg-white/5 border border-white/10 rounded-2xl p-8 hover:border-violet-500/30 hover:bg-violet-500/5 transition-all duration-300">
            <div class="w-14 h-14 bg-violet-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-violet-500/20 transition-colors">
              <svg class="w-7 h-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Páginas Web</h3>
            <p class="text-slate-400 leading-relaxed mb-4">
              Landing pages, sitios corporativos, portafolios y e-commerce. Diseño moderno, rápido y optimizado para convertir visitantes en clientes.
            </p>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Diseño responsive
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                SEO optimizado
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Carga ultra rápida
              </li>
            </ul>
          </div>

          <!-- Servicio 2: Desarrollo de Software -->
          <div class="group bg-white/5 border border-white/10 rounded-2xl p-8 hover:border-violet-500/30 hover:bg-violet-500/5 transition-all duration-300">
            <div class="w-14 h-14 bg-violet-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-violet-500/20 transition-colors">
              <svg class="w-7 h-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">Desarrollo de Software</h3>
            <p class="text-slate-400 leading-relaxed mb-4">
              Aplicaciones web y móviles a medida. Desde MVPs hasta plataformas completas con miles de usuarios. Tecnología escalable y moderna.
            </p>
            <ul class="space-y-2 text-sm text-slate-400">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Apps web & móviles
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                APIs & backends
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-violet-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>

/* Color mode */
@media (prefers-color-scheme: dark) {
  h1, h2, h3, p{
    color: hsl(0, 0%, 100%);
  }
  .button p{
    color: hsl(221, 39%, 11%);
  }
  .nav-links p{
    color: hsl(0, 0%, 100%);
  }
  body{
    background: var(--blue);
  }
  span{
      color: var(--soft-withe);
  }
  .primary-button{
    background-color: var(--soft-withe); 
  }
  .primary-button p{
    color: var(--soft-blue);
  }
  .secundary--button{
    background-color: var(--soft-blue);
  }
  .secundary--button p{
    color: var(--soft-withe);
  }
  .nav__item:hover{
    background: var(--soft-blue);
  }
  .nav__link{
    color: var(--soft-withe);
  }
  .button:hover{
      box-shadow: var(--soft-blue) 0px 0px 0px 4px, var(--soft-withe) 0px 0px 0px 7px, rgba(0, 0, 0, 0) 0px 0px 0px 0px;
  }
  .secundary--button:hover{
      box-shadow: var(--soft-blue) 0px 0px 0px 4px, var(--soft-withe) 0px 0px 0px 7px, rgba(0, 0, 0, 0) 0px 0px 0px 0px;
  }
  /* Dark incons */
  .change-lenguje svg path{
    fill: var(--soft-withe);
  }
  .nav__menu svg path{
    fill: var(--soft-withe);
  }
.change-lenguje:hover,
.nav__menu:hover{
background: var(--soft-blue);
}
.github__logo path {
  fill: white;
}
}

